<footer class="site-footer">
    <div class="container footer-grid">
        <div class="footer-col">
            <div class="footer-brand">SALUT</div>
            <p class="footer-tag">{{ site.tagline }} · {{ site.city }}</p>
            <p class="footer-desc">Trung tâm tiếng Pháp dành cho người bắt đầu từ con số 0 đến luyện thi TCF, DELF, TEF. Học cùng đội ngũ giảng viên trẻ, tận tâm, phương pháp vui và hiệu quả.</p>
            <div class="socials">
                {% if site.social.facebook %}<a href="{{ site.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg></a>{% endif %}
                {% if site.social.tiktok %}<a href="{{ site.social.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.84a8.16 8.16 0 0 0 4.77 1.52V6.94a4.85 4.85 0 0 1-1.84-.25z"/></svg></a>{% endif %}
                {% if site.social.youtube %}<a href="{{ site.social.youtube }}" target="_blank" rel="noopener" aria-label="YouTube"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.19a3 3 0 0 0-2.12-2.12C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.57A3 3 0 0 0 .5 6.19 31.26 31.26 0 0 0 0 12a31.26 31.26 0 0 0 .5 5.81 3 3 0 0 0 2.12 2.12C4.5 20.5 12 20.5 12 20.5s7.5 0 9.38-.57a3 3 0 0 0 2.12-2.12A31.26 31.26 0 0 0 24 12a31.26 31.26 0 0 0-.5-5.81zM9.75 15.5v-7l6.5 3.5z"/></svg></a>{% endif %}
            </div>
        </div>

        <div class="footer-col">
            <h4>Khoá học</h4>
            <ul>
                {% for c in courses | limit(5) %}
                    <li><a href="/khoa-hoc/{{ c.slug }}/">{{ c.short }}</a></li>
                {% endfor %}
                <li><a href="/khoa-hoc/">→ Xem tất cả</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Liên hệ</h4>
            <ul class="footer-contact">
                <li>🌐 {{ site.address }}</li>
                {% if site.phone %}<li>📞 <a href="tel:{{ site.phone | replace(' ', '') }}">{{ site.phone }}</a></li>{% endif %}
                {% if site.phoneFr %}<li>🇫🇷 {{ site.phoneFr }}</li>{% endif %}
                <li>✉️ <a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
                <li>💬 <a href="{{ site.social.facebook }}" target="_blank" rel="noopener">Messenger Salut</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Khám phá</h4>
            <ul>
                <li><a href="/ve-chung-toi/">Về Salut</a></li>
                <li><a href="/lich-khai-giang/">Lịch khai giảng</a></li>
                <li><a href="/cau-hoi-thuong-gap/">Câu hỏi thường gặp</a></li>
                <li><a href="/chinh-sach/">Chính sách học phí</a></li>
                <li><a href="/blog/">Blog</a></li>
                <li><a href="/lien-he/">Liên hệ</a></li>
            </ul>
        </div>
    </div>
    <div class="footer-bottom">
        <div class="container">
            <p>© {% year %} {{ site.name }}. Tous droits réservés. · Made with 🥐 in {{ site.city }}</p>
        </div>
    </div>
</footer>
