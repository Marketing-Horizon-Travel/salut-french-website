        </div>

        <div class="footer-col">
            <h4>Khoá học</h4>
            <ul>
                {% for c in courses | limit(5) %}
                    <li><a href="/khoa-hoc/{{ c.slug }}/">{{ c.short }}</a></li>
                {% endfor %}
                <li><a href="/khoa-hoc/">→ Xem tất cả</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Liên hệ</h4>
            <ul class="footer-contact">
                {% if site.phone %}<li><span class="fc-icon">📞</span><a href="tel:{{ site.phone | replace(' ', '') }}">{{ site.phone }}</a><span class="fc-tag">VN</span></li>{% endif %}
                {% if site.phoneFr %}<li><span class="fc-icon">📞</span><a href="tel:{{ site.phoneFr | replace(' ', '') }}">{{ site.phoneFr }}</a><span class="fc-tag">FR</span></li>{% endif %}
                {% if site.website %}<li><span class="fc-icon">🌐</span><a href="https://{{ site.website }}" target="_blank" rel="noopener">{{ site.website }}</a></li>{% endif %}
                <li><span class="fc-icon">✉️</span><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
            </ul>

            {% if site.handle %}
            <div class="footer-social-block">
                <p class="fsb-label">Theo dõi <strong>{{ site.handle }}</strong></p>
                <div class="footer-chips">
                    {% if site.social.instagram %}<a href="{{ site.social.instagram }}" target="_blank" rel="noopener" class="fchip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg> Instagram</a>{% endif %}
                    {% if site.social.tiktok %}<a href="{{ site.social.tiktok }}" target="_blank" rel="noopener" class="fchip"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.84a8.16 8.16 0 0 0 4.77 1.52V6.94a4.85 4.85 0 0 1-1.84-.25z"/></svg> TikTok</a>{% endif %}
                    {% if site.social.threads %}<a href="{{ site.social.threads }}" target="_blank" rel="noopener" class="fchip"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.781 3.631 2.695 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.323.143 1.504.708 2.604 1.78 3.182 3.099.806 1.839.881 4.835-1.55 7.213-1.86 1.819-4.118 2.638-7.312 2.66Zm1.036-7.965c-.115 0-.231.002-.348.005-1.83.103-2.986.937-2.928 2.121.063 1.24 1.427 1.817 2.74 1.746 1.207-.066 2.78-.534 3.044-3.7a10.59 10.59 0 0 0-2.508-.172z"/></svg> Threads</a>{% endif %}
