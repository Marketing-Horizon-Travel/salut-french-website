            </div>
            {% endif %}
        </div>

        <div class="footer-col">
            <h4>Khám phá</h4>
            <ul>
                <li><a href="/ve-chung-toi/">Về Salut</a></li>
                <li><a href="/lich-khai-giang/">Lịch khai giảng</a></li>
                <li><a href="/cau-hoi-thuong-gap/">Câu hỏi thường gặp</a></li>
                <li><a href="/chinh-sach/">Chính sách học phí</a></li>
                <li><a href="/blog/">Blog</a></li>
                <li><a href="/lien-he/">Liên hệ</a></li>
            </ul>
        </div>
    </div>
    <div class="footer-bottom">
        <div class="container">
            <p>© {% year %} {{ site.name }}. Tous droits réservés. · Made with 🥐 in {{ site.city }}</p>
        </div>
    </div>
</footer>
