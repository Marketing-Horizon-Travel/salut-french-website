<header class="site-header" id="site-header">
    <div class="header-inner container">
        <div class="site-brand">
            <a href="/" class="brand-link" aria-label="{{ site.name }} — trang chủ">
                <img src="/assets/images/logo.png" alt="{{ site.name }}" class="brand-logo" width="160" height="56" />
                <span class="brand-tag">{{ site.tagline }}</span>
            </a>
        </div>
        <nav class="site-nav" aria-label="Menu chính">
            <ul class="primary-menu">
                {% for item in site.nav %}
                    {% set isCurrent = page.url == item.url or (item.url != '/' and page.url.startsWith(item.url)) %}
                    {% if item.children %}
                        <li class="has-submenu{% if isCurrent %} is-current{% endif %}">
                            <a href="{{ item.url }}"{% if isCurrent %} class="current"{% endif %} aria-haspopup="true" aria-expanded="false">
                                {{ item.label }}
                                <svg class="submenu-caret" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                            </a>
                            <ul class="submenu" role="menu">
                                {% for child in item.children %}
                                    {% set childCurrent = page.url == child.url %}
                                    <li><a href="{{ child.url }}"{% if childCurrent %} class="current"{% endif %} role="menuitem">{{ child.label }}</a></li>
                                {% endfor %}
                            </ul>
                        </li>
                    {% else %}
                        <li><a href="{{ item.url }}"{% if isCurrent %} class="current"{% endif %}>{{ item.label }}</a></li>
                    {% endif %}
                {% endfor %}
            </ul>
        </nav>
        <div class="header-cta">
            <a href="/lien-he/" class="btn btn-primary">Đăng ký tư vấn</a>
        </div>
        <button class="menu-toggle" aria-label="Mở menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
</header>
