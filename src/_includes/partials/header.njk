<header class="site-header" id="site-header">
    <div class="header-inner container">
        <div class="site-brand">
            <a href="/" class="brand-link">
                <span class="brand-mark">SALUT</span>
                <span class="brand-tag">{{ site.tagline }}</span>
            </a>
        </div>
        <nav class="site-nav" aria-label="Menu chính">
            <ul class="primary-menu">
                {% for item in site.nav %}
                    <li><a href="{{ item.url }}"{% if page.url == item.url or (item.url != '/' and page.url.startsWith(item.url)) %} class="current"{% endif %}>{{ item.label }}</a></li>
                {% endfor %}
            </ul>
        </nav>
        <div class="header-cta">
            <a href="tel:{{ site.phone | replace(' ', '') }}" class="phone-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>{{ site.phone }}</span>
            </a>
            <a href="/lien-he/" class="btn btn-primary">Đăng ký tư vấn</a>
        </div>
        <button class="menu-toggle" aria-label="Mở menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
</header>
