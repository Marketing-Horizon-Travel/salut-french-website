---
layout: base.njk
pagination:
  data: courses
  size: 1
  alias: course
permalink: "/khoa-hoc/{{ course.slug }}/"
eleventyComputed:
  title: "{{ course.title }}"
  description: "{{ course.excerpt }}"
bodyClass: course-detail
---

<section class="course-hero">
    <div class="container grid-2">
        <div class="course-hero-text">
            <p class="page-kicker">Khoá học</p>
            <h1 class="page-title"><span class="title-icon">{% icon course.icon, 32 %}</span> {{ course.title }}</h1>
            <p class="page-lede">{{ course.excerpt }}</p>
            <ul class="course-stats">
                <li><strong>{{ course.duration }}</strong><span>Thời lượng</span></li>
                <li><strong>{{ course.sessions }}</strong><span>Số buổi</span></li>
                <li><strong>{{ course.goal }}</strong><span>Đầu ra</span></li>
                <li><strong>{{ course.price }}</strong><span>Học phí</span></li>
            </ul>
            <div class="hero-ctas">
                <a href="/lien-he/?khoa={{ course.slug }}" class="btn btn-primary btn-lg">Đăng ký khoá này</a>
                <a href="/khoa-hoc/" class="btn btn-outline">← Tất cả khoá học</a>
            </div>
        </div>
        <div class="course-hero-image">
            <div class="course-hero-placeholder">
                <span class="course-hero-icon">{% icon course.icon, 120 %}</span>
            </div>
        </div>
    </div>
</section>

<section class="single-content-section">
    <div class="container single-content">
        <h2>Giới thiệu khoá học</h2>
        <p>{{ course.description }}</p>

        <h2>Mục tiêu đầu ra</h2>
        <ul class="checklist">
            {% for outcome in course.outcomes %}
                <li>{% icon "circle-check", 18 %} {{ outcome }}</li>
            {% endfor %}
        </ul>

        {% if course.curriculum %}
            <h2>Chương trình học</h2>
            <div class="curriculum-timeline">
                {% for phase in course.curriculum %}
                    <div class="curriculum-item">
                        <div class="curriculum-week">{{ phase.week }}</div>
                        <div class="curriculum-topic">{{ phase.topic }}</div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{% set rows = schedule | where('course', course.slug) %}
{% if rows.length %}
<section class="schedule-section">
    <div class="container">
        <div class="section-head">
            <p class="section-kicker">Lịch khai giảng</p>
            <h2 class="section-title"><span class="accent">Sắp khai giảng</span> lớp {{ course.short }}</h2>
        </div>
        {% set courseSlug = course.slug %}
        {% include "partials/schedule-table.njk" %}
    </div>
</section>
{% endif %}

<section class="courses-section">
    <div class="container">
        <div class="section-head">
            <p class="section-kicker">Khoá học khác</p>
            <h2 class="section-title"><span class="accent">Bạn cũng</span> có thể thích</h2>
        </div>
        <div class="course-grid">
            {% set count = 0 %}
            {% for c in courses %}{% if c.slug != course.slug and count < 3 %}{% set count = count + 1 %}
                <article class="course-card">
                    <div class="course-icon">{% icon c.icon, 32 %}</div>
                    <h3 class="course-title"><a href="/khoa-hoc/{{ c.slug }}/">{{ c.title }}</a></h3>
                    <p class="course-excerpt">{{ c.excerpt }}</p>
                    <ul class="course-meta">
                        <li>{% icon "clock", 14 %} {{ c.duration }}</li>
                        <li>{% icon "target", 14 %} {{ c.goal }}</li>
                    </ul>
                    <div class="course-footer">
                        <span class="course-price">{{ c.price }}</span>
                        <a href="/khoa-hoc/{{ c.slug }}/" class="link-more">Chi tiết →</a>
                    </div>
                </article>
            {% endif %}{% endfor %}
        </div>
    </div>
</section>
