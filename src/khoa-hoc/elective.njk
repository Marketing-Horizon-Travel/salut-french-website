---
layout: base.njk
pagination:
  data: electives
  size: 1
  alias: elective
permalink: "/khoa-hoc/{{ elective.slug }}/"
eleventyComputed:
  title: "{{ elective.title }}"
  description: "{{ elective.lede }}"
bodyClass: elective-detail
---

<section class="course-hero course-hero-centered elective-hero">
    <div class="container">
        <div class="course-hero-text">
            <p class="page-kicker">{{ elective.kicker }}</p>
            <h1 class="page-title">{{ elective.title }}</h1>
            {% if elective.subtitle %}<p class="elective-subtitle">{{ elective.subtitle }}</p>{% endif %}
            <div class="elective-overview">
                <h2>Tổng quan khoá học</h2>
                <p>{{ elective.lede }}</p>
            </div>
            <div class="hero-ctas">
                <a href="/lien-he/?khoa={{ elective.slug }}" class="btn btn-primary btn-lg">{{ elective.cta }}</a>
                <a href="/khoa-hoc/" class="btn btn-outline">← Tất cả khoá học</a>
            </div>
        </div>
    </div>
</section>

<section class="why-section">
    <div class="container">
        <div class="section-head">
            <p class="section-kicker">Khác biệt cốt lõi</p>
            <h2 class="section-title">{{ elective.differentiatorsTitle }}</h2>
        </div>
        <div class="why-grid">
            {% for d in elective.differentiators %}
                <div class="why-card">
                    <div class="why-icon">{% icon d.icon, 36 %}</div>
                    <h3>{{ d.title }}</h3>
                    <p>{{ d.desc }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="single-content-section elective-audience-section">
    <div class="container single-content">
        <div class="section-head">
            <p class="section-kicker">Đối tượng phù hợp</p>
            <h2 class="section-title">{{ elective.audienceTitle }}</h2>
        </div>
        <ul class="audience-list">
            {% for item in elective.audience %}
                <li class="audience-card">
                    <span class="audience-number" aria-hidden="true">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
                    <p>{{ item }}</p>
                </li>
            {% endfor %}
        </ul>

        {% if elective.note %}
            <aside class="elective-note">
                <span class="elective-note-icon" aria-hidden="true">{% icon "lightbulb", 22 %}</span>
                <div>
                    <strong>Lưu ý quan trọng</strong>
                    <p>{{ elective.note }}</p>
                </div>
            </aside>
        {% endif %}

        {% if elective.founderNote %}
            <blockquote class="founder-callout">
                <span class="founder-callout-label">Lời khuyên từ Founder</span>
                <p>{{ elective.founderNote }}</p>
            </blockquote>
        {% endif %}
    </div>
</section>

<section class="courses-section">
    <div class="container">
        <div class="section-head">
            <p class="section-kicker">Khoá học khác</p>
            <h2 class="section-title"><span class="accent">Bạn cũng</span> có thể thích</h2>
        </div>
        <div class="course-levels">
            {% set count = 0 %}
            {% for e in electives %}{% if e.slug != elective.slug and count < 2 %}{% set count = count + 1 %}
                <a href="/khoa-hoc/{{ e.slug }}/" class="level-card">
                    <h3 class="level-title">{{ e.short }}</h3>
                    <p class="level-goal">{{ e.lede }}</p>
                    <span class="level-link">Xem chi tiết →</span>
                </a>
            {% endif %}{% endfor %}
            {% for c in courses | limit(2) %}
                <a href="/khoa-hoc/{{ c.slug }}/" class="level-card">
                    <h3 class="level-title">{{ c.short }}</h3>
                    <p class="level-goal">{{ c.excerpt }}</p>
                    <span class="level-link">Xem chi tiết →</span>
                </a>
            {% endfor %}
        </div>
    </div>
</section>
